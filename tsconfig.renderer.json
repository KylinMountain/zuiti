{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "declaration": false,
    "types": [],
    "noEmit": true
  },
  "include": ["src/renderer/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
