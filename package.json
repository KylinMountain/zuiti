{
  "name": "mira",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "description": "嘴替（codename: Mira）—— 你负责想，它负责嘴。TRAE AI 创造力大赛参赛作品。",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:node": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build:node && node --test \"dist/test/*.test.js\"",
    "coach": "npm run build:node && node dist/cli/coach.js",
    "start": "npm run build:node && electron .",
    "dev": "npm run build:node && electron . --enable-logging"
  },
  "dependencies": {
    "@openai/agents": "^0.12.0",
    "dotenv": "^16.4.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^42.5.0",
    "typescript": "^5.6.0"
  }
}
